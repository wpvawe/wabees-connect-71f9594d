rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // BUG-01 fix — every rule evaluation used to fire an extra
    // `get()` on the caller's user doc (and up to 3 extra reads
    // inside the agents subtree). We now read the role + dataOwner
    // straight from the Firebase Auth custom-claim JWT (zero reads).
    //
    // Fallback: while custom claims are being back-filled for older
    // sessions, we still tolerate the legacy `users/{uid}.role` /
    // `agents/{uid}.status` lookups so signed-in users keep working
    // during the migration window. Delete the fallback branches once
    // every active session has a claim (24h after `set-user-claims.php`
    // backfill completes).

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.get('role', '') == 'admin'
        // Legacy fallback — remove after custom-claim rollout.
        || (
          !('role' in request.auth.token)
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    // Helper: Check if user is owner of this userId
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function hasActiveAgentDoc(ownerId) {
      return request.auth != null
        && request.auth.uid != ownerId
        && exists(/databases/$(database)/documents/users/$(ownerId)/agents/$(request.auth.uid))
        && !(get(/databases/$(database)/documents/users/$(ownerId)/agents/$(request.auth.uid))
             .data.get('status', 'active') in ['revoked', 'left']);
    }

    // Helper: Check if user is an active agent of this owner. The dataOwner
    // custom claim is only a routing hint; the agent doc remains the
    // revocation source of truth so stale tokens cannot keep access alive.
    function isAgentOf(ownerId) {
      return request.auth != null && (
        (request.auth.token.get('dataOwner', '') == ownerId && hasActiveAgentDoc(ownerId))
        // Legacy fallback — remove after custom-claim rollout.
        || (
          !('dataOwner' in request.auth.token)
          && hasActiveAgentDoc(ownerId)
        )
      );
    }

    function agentSelfUpdateKeys() {
      return [
        'status', 'leftAt', 'leftReason',
        'isOnline', 'lastSeenAt', 'email',
        'availability', 'availabilityUpdatedAt',
        'fcmToken', 'fcmTokenUpdatedAt', 'updatedAt'
      ];
    }

    function regularAgentConversationKeys() {
      return [
        'contactPhone', 'contactName', 'updatedAt',
        'lastMessage', 'lastMessageType', 'lastMessageAt',
        'unreadCount',
        'state', 'stateUpdatedAt', 'stateUpdatedByUid', 'stateUpdatedByEmail',
        'resolvedAt', 'snoozeUntil',
        'firstResponseAt', 'firstResponseMs', 'firstResponseByUid',
        'notesCount',
        'assignedAgentId', 'assignedAgentEmail', 'assignedAt',
        'assignedByUid', 'assignedByEmail'
      ];
    }

    function supervisorConversationKeys() {
      return regularAgentConversationKeys().concat([
        'isBlocked', 'blockedAt',
        'tags', 'priority', 'priorityRank',
        'isPinned', 'pinOrder'
      ]);
    }

    function selfAssignOnly(keys) {
      return !keys.hasAny(['assignedAgentId', 'assignedAgentEmail', 'assignedAt', 'assignedByUid', 'assignedByEmail'])
        || (
          request.resource.data.assignedAgentId == request.auth.uid
          && request.resource.data.assignedByUid == request.auth.uid
        );
    }

    function regularAgentCanCreateConversation() {
      return request.resource.data.keys().hasOnly(regularAgentConversationKeys())
        && selfAssignOnly(request.resource.data.keys());
    }

    function regularAgentCanUpdateConversation() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(regularAgentConversationKeys())
        && selfAssignOnly(request.resource.data.diff(resource.data).affectedKeys());
    }

    // Helper: Check if user is a supervisor-level agent of this owner
    // (can reassign, view all conversations, etc.). Missing role → 'agent'.
    // Supervisor-role check stays as a doc read because it changes rarely
    // and only guards a handful of endpoints — not worth another claim.
    function isSupervisorOf(ownerId) {
      return isAgentOf(ownerId)
        && exists(/databases/$(database)/documents/users/$(ownerId)/agents/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(ownerId)/agents/$(request.auth.uid))
          .data.get('role', 'agent') == 'supervisor';
    }

    // ============ USERS ============
    match /users/{userId} {
      // Admin can list ALL users (needed for getAllUsers, getPendingUsers queries)
      allow list: if isAdmin();

      // User can read their own doc, agent can read owner's doc, admin reads any
      allow get: if isOwner(userId) || isAgentOf(userId) || isAdmin();

      // User can create their own document (registration)
      allow create: if isOwner(userId);

      // User can update their own document, admin can update any user.
      // S2 fix — agents previously had unrestricted update on the owner's
      // user doc which meant an agent could write `role: "admin"` to
      // their own document (isOwner(agentUid) for their own root doc)
      // and self-escalate. Agents now get a narrow field allowlist —
      // they may only bump the counter fields the composer/campaigns
      // hooks already write (`totalMessages`, `totalCampaigns`) plus
      // low-risk activity stamps. Sensitive fields (role, plan, status,
      // dataOwner, whatsappAccessToken, apiKey, email) stay owner+admin.
      allow update: if isOwner(userId) || isAdmin()
        || (isAgentOf(userId)
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['totalMessages', 'totalCampaigns',
                           'lastActivityAt', 'updatedAt']));

      // Only admin can delete users
      allow delete: if isAdmin();

      // ============ WhatsApp Config ============
      match /whatsapp_config/{docId} {
        // Batch 4 (post Step B) — agent READ revoked. The Meta access
        // token no longer flows to the browser: PHP endpoints resolve
        // credentials server-side via `_wa_auth.php::wabees_apply_bearer_auth`
        // using the caller's verified Firebase bearer token and the
        // owner's `dataOwner` lookup. UI gating uses `loadWaConnection`
        // which reads only `users/{ownerId}.whatsappPhoneNumberId` (public
        // routing id, agent-readable via the users/{userId} rule above).
        // Owner + admin retain full access; writes stay owner+admin only
        // so the token cannot be replaced by an agent.
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ============ Agents ============
      match /agents/{agentId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        // Owner or admin can freely manage agents.
        allow write: if isOwner(userId) || isAdmin();
        // Invitee may create their OWN agent doc only when a matching
        // invite exists in the global mirror with acceptedBy == self and
        // ownerId == this workspace owner. This closes the C-2 escalation
        // where any signed-in user could create an agent doc under any
        // owner just because request.auth.uid == agentId.
        allow create: if request.auth != null
          && request.auth.uid == agentId
          && request.resource.data.inviteCode is string
          && exists(/databases/$(database)/documents/agent_invites/$(request.resource.data.inviteCode))
          && get(/databases/$(database)/documents/agent_invites/$(request.resource.data.inviteCode)).data.ownerId == userId
          && (
            // Either the invite is still pending (matching a same-batch
            // CAS from pending→accepted; the invite-update rule enforces
            // that only one such batch wins) OR the mirror already shows
            // acceptedBy == self (single-write path).
            get(/databases/$(database)/documents/agent_invites/$(request.resource.data.inviteCode)).data.status == 'pending'
            || get(/databases/$(database)/documents/agent_invites/$(request.resource.data.inviteCode)).data.acceptedBy == request.auth.uid
          );
        // Agent may update only its OWN operational fields (presence,
        // availability, FCM token, or voluntary leave). It cannot edit role,
        // workingHours, skills, activeLoad, or status back to active.
        allow update: if request.auth != null
          && request.auth.uid == agentId
          && resource.data.get('status', 'active') != 'revoked'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(agentSelfUpdateKeys())
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
            || request.resource.data.status == 'left'
          );
      }

      // ============ Messages ============
      // Agents can send/read messages but only owners can hard-delete rows.
      match /messages/{messageId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin()
          || (isSupervisorOf(userId) && request.resource.data.keys().hasOnly(supervisorConversationKeys()))
          || (isAgentOf(userId) && regularAgentCanCreateConversation());
        allow update: if isOwner(userId) || isAdmin()
          || (isSupervisorOf(userId)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(supervisorConversationKeys()))
          || (isAgentOf(userId) && regularAgentCanUpdateConversation());
        allow delete: if isOwner(userId) || isAdmin();
      }

      // ============ Conversations ============
      // Agents can mutate state (block/resolve/assign) but only owners
      // can hard-delete an entire thread.
      match /conversations/{convId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        allow create, update: if isOwner(userId) || isAgentOf(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      // ============ Contacts ============
      // Agents may READ contacts to power inbox lookups but CANNOT create/
      // edit/delete — that stays with the owner. Frontend hides the buttons;
      // rules enforce it against direct REST calls.
      match /contacts/{contactId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ============ Bots ============ (owner-only writes)
      match /bots/{botId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ============ Campaigns ============ (owner-only writes)
      match /campaigns/{campaignId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();

        match /logs/{logId} {
          allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
          allow write: if isOwner(userId) || isAdmin();
        }
      }

      // ============ Templates ============
      // Agents may read + send but not create/edit/delete templates.
      match /templates/{templateId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ============ Canned Responses (Quick Replies) ============
      // Owner-managed library, agents read only (they trigger from composer).
      match /canned/{cannedId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ============ Settings (SLA targets, etc.) ============
      // Owner writes; agents inherit read-only so the badge renders.
      match /settings/{docId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ============ Subscription ============
      match /subscription/{docId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        // Admin has full control (assign / extend / change plan).
        // Owner may only:
        //   - CREATE the initial welcome subscription doc (bootstrap on signup)
        //   - UPDATE the *Used counter fields and updatedAt (usage bookkeeping)
        // Owner CANNOT modify max*, endDate, status, planId, expiryType/Days
        // — otherwise a user could raise their own cap or reset the counter.
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isAdmin()
          || (isOwner(userId)
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['messagesUsed','contactsUsed','campaignsUsed',
                             'botsUsed','templatesUsed','aiMessagesUsed',
                             'agentsUsed','updatedAt']));
        allow delete: if isAdmin();
      }

      // ============ Notifications ============
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId) || isAgentOf(userId);
        // Admin can create notifications (e.g. support reply, plan activation)
        // Admin can also read/delete (for monitoring)
        allow read, write: if isAdmin();
      }


      // ============ Internal Notes (per conversation subcollection) ============
      match /conversations/{convId}/notes/{noteId} {
        allow read, write: if isOwner(userId) || isAgentOf(userId);
        allow read: if isAdmin();
      }

      // ============ Assignment audit log (per conversation subcollection) ============
      // S8 fix — audit log is append-only. Owners + agents can create
      // entries and read history; nobody may update or delete an entry
      // (owners keep delete via admin SDK if a wipe is ever needed).
      match /conversations/{convId}/assign_log/{logId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        allow create: if isOwner(userId) || isAgentOf(userId);
      }

      // ============ Scheduled Messages ============
      match /scheduled_messages/{msgId} {
        allow read, write: if isOwner(userId) || isAgentOf(userId);
        allow read, write: if isAdmin();
      }

      // ============ Tags ============
      match /tags/{tagId} {
        allow read, write: if isOwner(userId) || isAgentOf(userId);
        allow read, write: if isAdmin();
      }

      // ============ Products (Catalog) ============
      match /products/{productId} {
        allow read, write: if isOwner(userId);
        allow read, write: if isAdmin();
      }

      // ============ Call Logs ============
      match /call_logs/{callId} {
        allow read, write: if isOwner(userId) || isAgentOf(userId);
        allow read, write: if isAdmin();
      }

      // ============ CSAT Surveys ============
      // Owner + agents create surveys on resolve. Reads shared with team.
      match /csat_surveys/{surveyId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        allow create, update: if isOwner(userId) || isAgentOf(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      // ============ Calls (active/signaling) ============
      match /calls/{callId} {
        allow read, write: if isOwner(userId) || isAgentOf(userId);
      }

      // ============ AI Bot Config (owner-only, NO agent access) ============
      match /bot_config/{docId} {
        allow read, write: if isOwner(userId);
        allow read, write: if isAdmin();
      }

      // ============ AI Bot Usage (owner-only, NO agent access) ============
      match /bot_usage/{docId} {
        allow read, write: if isOwner(userId);
        allow read, write: if isAdmin();
      }

      // ============ AI Bot Leads (owner-only, NO agent access) ============
      match /bot_leads/{docId} {
        allow read, write: if isOwner(userId);
        allow read, write: if isAdmin();
      }

      // ============ Analytics Daily Rollup ============
      // Client-side computed per-day aggregate cache under the owner's
      // subtree. Only the owner (and their agents / admin) may read; only
      // the owner writes — agents don't compute rollups.
      match /analytics_daily/{dayId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ============ Agent Invites (owner's own list) ============
      // Owner creates/revokes invite tokens; agents can read for future
      // supervisor UI. Global mirror at /agent_invites/{code} handles the
      // invitee's lookup after signup.
      match /agent_invites/{inviteId} {
        allow read: if isOwner(userId) || isAgentOf(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId) || isAdmin();
        // The accepter (invitee) may flip THIS owner-scoped mirror from
        // pending→accepted after the global mirror already shows their
        // uid in `acceptedBy`. Keeps the owner's Pending Invites card
        // accurate without needing an admin SDK.
        allow update: if request.auth != null
          && resource.data.status == 'pending'
          && request.resource.data.status == 'accepted'
          && resource.data.code is string
          && request.resource.data.code == resource.data.code
          && exists(/databases/$(database)/documents/agent_invites/$(resource.data.code))
          && get(/databases/$(database)/documents/agent_invites/$(resource.data.code)).data.acceptedBy == request.auth.uid;
      }
    }

    // ============ PLANS (Global) ============
    match /plans/{planId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ============ SUPPORT CHATS ============
    match /support_chats/{chatId} {
      // User can read/write their own chat (chatId == userId)
      allow read, write: if request.auth != null && request.auth.uid == chatId;
      // Admin can read/write all chats + list all
      allow read, write, list: if isAdmin();

      // Messages inside a support chat
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == chatId;
        allow read, write: if isAdmin();
      }
    }

    // ============ PENDING SUBSCRIPTIONS (Global for Admin) ============
    match /pending_subscriptions/{docId} {
      // Admin can read/write/list all pending subscriptions
      allow read, write, list: if isAdmin();
      // User can create/update their own pending subscription request (docId == userId)
      allow create, update: if request.auth != null && docId == request.auth.uid;
      // Allow user to read their own pending request (docId == userId)
      allow read: if request.auth != null && docId == request.auth.uid;
      // User can delete their own pending request (cancel)
      allow delete: if request.auth != null && docId == request.auth.uid;
    }

    // ============ ADMIN NOTIFICATIONS (Global) ============
    match /admin_notifications/{notificationId} {
      allow read, write, list: if isAdmin();
      // Any authenticated user can create admin notifications (e.g. plan
      // requests) but only with a bounded, well-shaped payload — otherwise
      // a rogue client could spam the admin inbox with huge/arbitrary docs.
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(
             ['title', 'body', 'type', 'data', 'read', 'createdAt', 'userId', 'userEmail', 'userName']
           )
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 500
        && request.resource.data.type is string
        && request.resource.data.type.size() <= 40
        && request.resource.data.read == false;
    }

    // ============ ADMIN AUDIT LOG (Global, append-only) ============
    match /admin_audit_logs/{logId} {
      allow read, list: if isAdmin();
      // Admins may append entries; no updates/deletes so the trail stays intact.
      allow create: if isAdmin();
    }

    // ============ WA_MAP (WhatsApp phone_number_id → userId for webhook routing) ============
    match /wa_map/{phoneNumberId} {
      // Backend service account reads/writes via admin SDK (bypasses rules)
      // Client reads: user reads only their OWN mapping. The consent-flow
      // pre-check runs through the server function (service account) so it
      // does not need public read access here.
      allow read: if request.auth != null && (
        resource == null || resource.data.userId == request.auth.uid
      );
      // CREATE: only when no mapping exists AND caller claims themselves.
      // Prevents a second account from silently overwriting an existing
      // owner's phone_number_id → userId mapping via direct Firestore write.
      allow create: if request.auth != null
        && resource == null
        && request.resource.data.userId == request.auth.uid;
      // UPDATE: only the current owner may mutate their own mapping and
      // may NOT re-assign it to another uid.
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      // DELETE: only the current owner.
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      // Admin can manage all mappings
      allow read, write, list: if isAdmin();
    }

    // ============ SYSTEM CONFIG (announcement, app_version) ============
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ============ APP CONFIG (AI bot master prompt, etc.) ============
    match /app_config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ============ GLOBAL SETTINGS (subscription_messages, etc.) ============
    // Any authenticated user can read (e.g. plan request dialog needs
    // paymentInstructions / adminContact). Only admin can write.
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ============ AGENT INVITES (global code lookup) ============
    // Global short-code → invite metadata so an invited user can look up
    // the owner immediately after signup. Auth required to prevent
    // anonymous enumeration. Only the referenced owner can create/revoke,
    // and only the accepter (writing their own uid into acceptedBy) can
    // flip status from 'pending' → 'accepted'.
    match /agent_invites/{code} {
      // Single-doc GET is public so an invited user can open the link in a
      // fresh browser (signed-out) and see the invite card before signing
      // in. Enumeration is prevented by keeping `list` admin-only and by
      // the code being an unguessable random string.
      allow get: if true;
      allow list: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        (
          resource.data.status == 'pending'
          && request.resource.data.status == 'accepted'
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.role == resource.data.role
          && request.resource.data.inviteId == resource.data.inviteId
          && request.resource.data.acceptedBy == request.auth.uid
        )
      );
    }
  }
}
